using UnityEngine;

public class Teleport : MonoBehaviour
{
    // Campo público para asignar el punto de destino en el Inspector
    public Transform teleportPoint;

    // Método que se ejecuta cuando el jugador entra en el trigger
    private void OnTriggerEnter(Collider other)
    {
        // Accedemos al transform del objeto que entró (el jugador)
        // y cambiamos su posición por la del punto de destino
        other.transform.position = teleportPoint.position;

        Debug.Log("Teleportado a: " + teleportPoint.name);
    }
}
